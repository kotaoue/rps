{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "style.css", "use": "@vercel/static" },
    { "src": "javascript/**", "use": "@vercel/static" },
    { "src": "nextjs/package.json", "use": "@vercel/next" },
    { "src": "astro/package.json", "use": "@vercel/static-build", "config": { "distDir": ".vercel/output" } }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "^/node/?$", "dest": "/api/node" },
    { "src": "^/go/?$", "dest": "/api/go" },
    { "src": "^/typescript/?$", "dest": "/api/typescript" }
  ]
}
